# AUDIENCE: public
# DMRZL setup config — copy this to setup.config.env (gitignored) and fill values.
# Each UPPER_SNAKE_CASE key maps to a {{lower_snake_case}} placeholder
# substituted into shipped files by `setup.sh apply`.

# ── Identity ──────────────────────────────────────────────────────────
# Your local OS username (output of `whoami`). Used in macOS/Linux paths
# embedded in scripts, e.g. `~/.claude/projects/-Users-<USER_HANDLE>-...`.
# Not the GitHub handle.
USER_HANDLE="your-handle"

# Response language. Default English.
# Suggested: en (English), ukr (Ukrainian), es (Spanish), ... — any
# language code or full name works. Substituted into PERSONA.md so
# the agent responds in this language.
LANGUAGE="en"

# ── Project ───────────────────────────────────────────────────────────
# GitHub organization or user that owns the project repository.
# Used in CI commands like `gh run list --repo {GITHUB_OWNER}/{PROJECT_NAME}`.
# Not required if you don't push to GitHub — leave as-is and ignore CI hints.
GITHUB_OWNER="your-github-handle"

# Display name of the project the agent works on. Used in agent rules,
# CI commands, docs, and skill examples.
PROJECT_NAME="MyProject"

# Lowercase URL-safe form of PROJECT_NAME. Used as a vault folder name
# (`vault/<PROJECT_SLUG>/`) and other path segments.
PROJECT_SLUG="myproject"

# Source folder name inside your target project (e.g. `src`, `Sources`,
# `lib`). Referenced in skill paths and agent rules.
SRC_DIR="Sources"

# ── Filesystem (absolute paths) ───────────────────────────────────────
# Your home directory.
HOME="/Users/you"

# Absolute path to THIS clone (the agent workspace).
WORKSPACE_ROOT="/Users/you/Projects/AgentWorkspace"

# Folder name only — last segment of WORKSPACE_ROOT. Used in Claude Code
# memory paths: `~/.claude/projects/-Users-<USER_HANDLE>-Projects-<WORKSPACE_DIR>/`.
WORKSPACE_DIR="AgentWorkspace"

# Absolute path to your target project repo (where the agent works on code).
PROJECT_ROOT="/Users/you/Projects/MyProject"
