{
  "permissions": {
    "allow": [
      "mcp__obsidian__search-vault",
      "mcp__obsidian__read-note",
      "mcp__obsidian__edit-note",
      "mcp__obsidian__create-note",
      "mcp__obsidian__list-available-vaults"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/dmrzl-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/safety-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-meta-edit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-vault-language.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|mcp__obsidian__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/file-tracker.sh"
          }
        ]
      }
    ]
  }
}
